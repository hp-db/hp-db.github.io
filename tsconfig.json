{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "src/**",
    "static/**",
    "dist/**",
    "plugins/**",
    "store/index.js",
    "nuxt.config.js",
    "index.d.ts",
    "pages/**",
    "layouts/**",
    "components/search/**",
    "components/custom/**",
    "components/display/**",
    "components/common/ShareButtons.vue",
    "components/common/Breadcrumbs.vue",
    "components/common/Map.vue",
    "components/common/TOC.vue",
    "components/common/Split.vue"
  ]
}
